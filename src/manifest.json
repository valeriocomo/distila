{
  "manifest_version": 3,
  "name": "Distila",
  "version": "1.1.0",
  "description": "Distila: summarizes the article on the current page using Chrome's on-device Summarizer API.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Distila — Summarize article",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "offscreen",
    "storage"
  ]
}